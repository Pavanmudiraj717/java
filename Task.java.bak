class Task 
{
	public static void main(String[] args) 
	{
	int num=3;
	for(int i=1;i<=num;i++)
		{
		int n=i;
		for(int j=1;j<2*num;j++)
			{
			if(i+j<num && j-1<num)
				{
				if(j<num)
					{
					System.out.print("i ");
					}
					else
					{
						System.out.print("  ");
					}
				}
				System.out.println();
			}

	}
}
}
